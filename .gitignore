# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.jks
*.keystore
google-services.json
GoogleService-Info.plist
firebase_options.dart
secrets.dart
**/secrets/
.pub-credentials.json

